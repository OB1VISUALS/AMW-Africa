    <!-- GLOBAL CONNECTION / FOOTER -->
    <footer class="global-footer">
      <div class="footer-text">
        <p>
          A MILLION WOMEN AFRICA · CONTINENTAL EXPRESSION OF THE GLOBAL MOVEMENT
          FOUNDED BY PAPA LOU ENGLE
